---
interface Props {
  as?: 'h1' | 'h2' | 'h3';
  centered?: boolean;
  class?: string;
}

const { as: Tag = 'h2', centered = true, class: className = '' } = Astro.props;
const baseClasses = 'text-3xl md:text-4xl font-bold text-white';
const centerClass = centered ? 'text-center' : '';
---

<Tag class:list={[baseClasses, centerClass, className]}>
  <slot />
</Tag>
