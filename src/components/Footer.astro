  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col items-center justify-center space-y-4">
      <div class="text-2xl font-bold text-teal-900/50 font-mono">&lt;Dev /&gt;</div>
      <p class="text-sm">&copy; {currentYear} Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-teal-400 transition-colors">Astro</a> & <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-teal-400 transition-colors">Tailwind CSS</a>.</p>
    </div>
  </div>
</footer>
