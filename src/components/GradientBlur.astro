<!-- h-[20%] = 20% viewport height provides a subtle blur zone at the bottom without obscuring main content -->
<div
  id="gradient-blur"
  class="gradient-blur pointer-events-none fixed inset-x-0 bottom-0 z-40 h-[20%] transition-opacity duration-500 ease-out"
  aria-hidden="true"
>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
</div>

<script>
  const gradientBlur = document.getElementById('gradient-blur');
  const footer = document.querySelector('footer');

  if (gradientBlur && footer) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            gradientBlur.style.opacity = '0';
          } else {
            gradientBlur.style.opacity = '1';
          }
        });
      },
      {
        root: null,
        threshold: 0.1,
      },
    );

    observer.observe(footer);
  }
</script>

<style>
