<section id="contact" class="fade-in-section py-20 md:py-32 bg-slate-900 text-center relative overflow-hidden">
  <div class="absolute inset-0 z-0">
     <div class="absolute bottom-0 left-0 w-96 h-96 bg-teal-500/10 rounded-full mix-blend-screen filter blur-3xl opacity-20"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-8 text-white">Get In Touch</h2>
    <p class="text-xl text-slate-300 mb-12 max-w-2xl mx-auto">
      I'm currently open to new opportunities. Whether you have a question or just want to say hi, I'll try my best to get back to you!
    </p>
    <a href="mailto:hello@example.com" class="inline-block px-8 py-4 bg-teal-500 hover:bg-teal-400 text-slate-900 font-bold rounded-lg text-lg transition-transform transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2 focus:ring-offset-slate-900 shadow-lg shadow-teal-500/20">
      Say Hello
    </a>
  </div>
</section>
