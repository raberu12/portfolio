---
import vscodeIcon from '../../assets/images/vscode.svg';

const iconColor = '2dd4bf'; // teal-400

const skills = [
  { name: 'Astro', icon: `https://cdn.simpleicons.org/astro/${iconColor}` },
  { name: 'React', icon: `https://cdn.simpleicons.org/react/${iconColor}` },
  { name: 'TypeScript', icon: `https://cdn.simpleicons.org/typescript/${iconColor}` },
  { name: 'Tailwind CSS', icon: `https://cdn.simpleicons.org/tailwindcss/${iconColor}` },
  { name: 'Next.js', icon: `https://cdn.simpleicons.org/nextdotjs/${iconColor}` },
  { name: 'Node.js', icon: `https://cdn.simpleicons.org/nodedotjs/${iconColor}` },
  { name: 'Express', icon: `https://cdn.simpleicons.org/express/${iconColor}` },
  { name: 'PostgreSQL', icon: `https://cdn.simpleicons.org/postgresql/${iconColor}` },
  { name: 'Supabase', icon: `https://cdn.simpleicons.org/supabase/${iconColor}` },
  { name: 'Git', icon: `https://cdn.simpleicons.org/git/${iconColor}` },
  { name: 'Docker', icon: `https://cdn.simpleicons.org/docker/${iconColor}` },
  { name: 'VS Code', icon: vscodeIcon.src },
  { name: 'Figma', icon: `https://cdn.simpleicons.org/figma/${iconColor}` },
  { name: 'Linux', icon: `https://cdn.simpleicons.org/linux/${iconColor}` },
];

// Split skills into 3 columns with some variety
const column1 = [skills[0], skills[3], skills[6], skills[9], skills[12]];
const column2 = [skills[1], skills[4], skills[7], skills[10], skills[13]];
const column3 = [skills[2], skills[5], skills[8], skills[11], skills[0]];
---

<section id="skills" class="fade-in-section py-20 md:py-32 bg-slate-900/80 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mb-12">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-white">Technical Skills</h2>
  </div>

  <!-- Carousel Container -->
  <div class="skills-carousel-container relative h-[400px] md:h-[500px]">
    <!-- 3 Column Grid -->
    <div class="flex justify-center gap-4 md:gap-8 h-full px-4">
      <!-- Column 1: Top to Bottom -->
      <div class="skills-column skills-column-down overflow-hidden">
        <div class="scroll-track scroll-down">
          {[...column1, ...column1].map((skill, i) => (
            <div class="skill-item my-4" aria-hidden={i >= column1.length}>
              <div class="flex flex-col items-center gap-3 p-4 md:p-6 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-teal-500/50 hover:bg-slate-800 transition-all group w-[100px] md:w-[130px]">
                <img
                  src={skill.icon}
                  alt={i < column1.length ? `${skill.name} logo` : ''}
                  class="w-10 h-10 md:w-12 md:h-12 group-hover:scale-110 transition-transform"
                  loading="lazy"
                />
                <span class="text-sm md:text-base text-slate-300 font-medium text-center whitespace-nowrap">{skill.name}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Column 2: Bottom to Top -->
      <div class="skills-column skills-column-up overflow-hidden">
        <div class="scroll-track scroll-up">
          {[...column2, ...column2].map((skill, i) => (
            <div class="skill-item my-4" aria-hidden={i >= column2.length}>
              <div class="flex flex-col items-center gap-3 p-4 md:p-6 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-teal-500/50 hover:bg-slate-800 transition-all group w-[100px] md:w-[130px]">
                <img
                  src={skill.icon}
                  alt={i < column2.length ? `${skill.name} logo` : ''}
                  class="w-10 h-10 md:w-12 md:h-12 group-hover:scale-110 transition-transform"
                  loading="lazy"
                />
                <span class="text-sm md:text-base text-slate-300 font-medium text-center whitespace-nowrap">{skill.name}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Column 3: Top to Bottom -->
      <div class="skills-column skills-column-down overflow-hidden">
        <div class="scroll-track scroll-down">
          {[...column3, ...column3].map((skill, i) => (
            <div class="skill-item my-4" aria-hidden={i >= column3.length}>
              <div class="flex flex-col items-center gap-3 p-4 md:p-6 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-teal-500/50 hover:bg-slate-800 transition-all group w-[100px] md:w-[130px]">
                <img
                  src={skill.icon}
                  alt={i < column3.length ? `${skill.name} logo` : ''}
                  class="w-10 h-10 md:w-12 md:h-12 group-hover:scale-110 transition-transform"
                  loading="lazy"
                />
                <span class="text-sm md:text-base text-slate-300 font-medium text-center whitespace-nowrap">{skill.name}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-carousel-container {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .skills-column {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .scroll-track {
    display: flex;
    flex-direction: column;
  }

  .scroll-down {
    animation: scrollDown 20s linear infinite;
  }

  .scroll-up {
    animation: scrollUp 20s linear infinite;
  }

  @keyframes scrollDown {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  @keyframes scrollUp {
    0% {
      transform: translateY(-50%);
    }
    100% {
      transform: translateY(0);
    }
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .scroll-track {
      animation: none !important;
    }

    .skill-item[aria-hidden="true"] {
      display: none;
    }
  }
</style>
