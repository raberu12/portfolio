---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.featured === b.data.featured ? 0 : a.data.featured ? -1 : 1));
---

<section id="projects" class="fade-in-section py-20 md:py-32 bg-slate-950 text-slate-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center text-white">Featured Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedProjects.map((project) => (
        <div class="bg-slate-900 rounded-xl overflow-hidden border border-slate-800 hover:border-teal-500/50 transition-all hover:shadow-xl hover:-translate-y-1 group flex flex-col h-full">
          <div class="h-48 bg-slate-800 relative overflow-hidden group-hover:opacity-90 transition-opacity">
            {project.data.featuredImage ? (
                <Image src={project.data.featuredImage} alt={project.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            ) : (
                <div class="w-full h-full bg-slate-800 flex items-center justify-center text-slate-600 bg-gradient-to-br from-slate-800 to-slate-900">
                   <span class="text-4xl font-mono opacity-20">&lt;/&gt;</span>
                </div>
            )}
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-bold mb-2 text-white group-hover:text-teal-400 transition-colors">{project.data.title}</h3>
            <p class="text-slate-400 mb-4 line-clamp-3 flex-grow">{project.data.summary}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.data.tech.map((t) => (
                <span class="px-2 py-1 bg-slate-800 text-teal-400 text-xs font-medium rounded border border-slate-700">{t}</span>
              ))}
            </div>
            <div class="flex gap-4 mt-auto">
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors flex items-center gap-1 text-sm font-medium">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  Code
                </a>
              )}
              {project.data.liveUrl && (
                <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors flex items-center gap-1 text-sm font-medium">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                  Live Demo
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
