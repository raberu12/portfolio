---
const experiences = [
  {
    role: "Senior Frontend Engineer",
    company: "Tech Corp",
    period: "2021 - Present",
    description: "Leading frontend architecture and improved core web vitals by 40%. Implemented a modern component library using React and Tailwind."
  },
  {
    role: "Full Stack Developer",
    company: "Startup Inc",
    period: "2019 - 2021",
    description: "Built and scaled SaaS products from zero to 10k users. Managed the entire stack from AWS infrastructure to React frontend."
  },
  {
    role: "Junior Web Developer",
    company: "Digital Agency",
    period: "2018 - 2019",
    description: "Developed responsive websites for various clients. Collaborated with designers to ensure pixel-perfect implementation."
  }
];
---
<section id="experience" class="fade-in-section py-20 md:py-32 bg-slate-800 relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center text-white">Experience</h2>
    <div class="relative border-l border-slate-700 ml-4 md:ml-0 space-y-12">
      {experiences.map((exp, index) => (
        <div class="mb-10 ml-10 relative group">
          <span class="absolute -left-[3.2rem] top-1 h-5 w-5 rounded-full border-4 border-slate-800 bg-teal-500 group-hover:scale-125 transition-transform duration-300"></span>
          <div class="bg-slate-900/50 p-6 rounded-lg border border-slate-700/50 group-hover:border-teal-500/30 transition-all hover:bg-slate-900 hover:shadow-xl">
             <div class="flex flex-col md:flex-row md:justify-between md:items-center mb-2">
                <h3 class="text-xl font-bold text-white group-hover:text-teal-300 transition-colors">{exp.role}</h3>
                <span class="text-teal-400 text-sm font-mono bg-teal-500/10 px-2 py-1 rounded">{exp.period}</span>
             </div>
             <p class="text-lg text-slate-400 mb-4 font-medium">{exp.company}</p>
             <p class="text-slate-300 leading-relaxed">{exp.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
