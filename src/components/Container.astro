---
interface Props {
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '4xl' | '6xl' | '7xl';
  class?: string;
}

const maxWidthClasses = {
  sm: 'max-w-sm',
  md: 'max-w-md',
  lg: 'max-w-lg',
  xl: 'max-w-xl',
  '2xl': 'max-w-2xl',
  '4xl': 'max-w-4xl',
  '6xl': 'max-w-6xl',
  '7xl': 'max-w-7xl',
};

const { maxWidth = '6xl', class: className = '' } = Astro.props;
const widthClass = maxWidthClasses[maxWidth];
---

<div class:list={[widthClass, 'mx-auto px-4 sm:px-6 lg:px-8', className]}>
  <slot />
</div>
